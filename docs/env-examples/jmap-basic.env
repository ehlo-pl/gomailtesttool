# JMAP — Basic (password) auth for self-hosted JMAP servers (Cyrus IMAP, Apache James)
# Usage: set these variables, then run:
#   gomailtest jmap testconnect|testauth|getmailboxes

# ── Connection ───────────────────────────────────────────────────────────────
JMAPHOST=jmap.example.com
JMAPPORT=443
# JMAPADDRESS=192.168.1.10  # connect to this IP instead of JMAPHOST (host still used for TLS SNI)
# JMAPIPV4=false
# JMAPIPV6=false

# ── TLS ──────────────────────────────────────────────────────────────────────
# JMAPSKIPVERIFY=false  # useful for self-signed certs on self-hosted servers

# ── Authentication ───────────────────────────────────────────────────────────
JMAPUSERNAME=user@example.com
JMAPPASSWORD=change-me
JMAPAUTHMETHOD=basic

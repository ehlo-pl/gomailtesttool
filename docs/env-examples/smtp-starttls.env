# SMTP — password auth over STARTTLS (port 587)
# Usage: set these variables, then run:
#   gomailtest smtp testconnect|teststarttls|testauth

# ── Connection ───────────────────────────────────────────────────────────────
SMTPHOST=smtp.example.com
SMTPPORT=587
SMTPSTARTTLS=true
# SMTPTIMEOUT=30
# SMTPADDRESS=         # connect to this IP instead of SMTPHOST (host still used for TLS SNI)
# SMTPIPV4=false       # force IPv4
# SMTPIPV6=false       # force IPv6
# SMTPPROXY=http://proxy.example.com:8080

# ── TLS ──────────────────────────────────────────────────────────────────────
# SMTPSKIPVERIFY=false # skip certificate verification (testing only)
# SMTPTLSVERSION=1.2   # minimum TLS version; 1.2 or 1.3

# ── Authentication ───────────────────────────────────────────────────────────
SMTPUSERNAME=user@example.com
SMTPPASSWORD=change-me
# SMTPAUTHMETHOD=auto  # auto-selects strongest advertised method: CRAM-MD5 > NTLM > PLAIN > LOGIN

# ── Output ────────────────────────────────────────────────────────────────────
# SMTPVERBOSE=false
# SMTPLOGLEVEL=INFO   # DEBUG, INFO, WARN, ERROR

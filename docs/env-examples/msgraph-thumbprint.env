# Microsoft Graph — Windows certificate store auth via thumbprint (Windows only)
# Certificate must be present in the CurrentUser\My store on the machine running gomailtest.
# Usage: set these variables, then run:
#   gomailtest msgraph testconnect|testauth|getevents|getinbox

# ── Authentication ───────────────────────────────────────────────────────────
MSGRAPHTENANTID=00000000-0000-0000-0000-000000000000
MSGRAPHCLIENTID=00000000-0000-0000-0000-000000000000
MSGRAPHTHUMBPRINT=CD817B3329802E692CF30D8DDF896FE811B048AB
MSGRAPHMAILBOX=user@example.com

# ── Optional ─────────────────────────────────────────────────────────────────
# MSGRAPHPROXY=http://proxy.example.com:8080
# MSGRAPHMAXRETRIES=3
# MSGRAPHRETRYDELAY=2000

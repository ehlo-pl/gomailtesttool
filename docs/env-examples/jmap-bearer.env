# JMAP — Bearer token auth (Fastmail and similar providers)
# Usage: set these variables, then run:
#   gomailtest jmap testconnect|testauth|getmailboxes

# ── Connection ───────────────────────────────────────────────────────────────
JMAPHOST=jmap.fastmail.com
JMAPPORT=443
# JMAPADDRESS=         # connect to this IP instead of JMAPHOST (host still used for TLS SNI)
# JMAPIPV4=false
# JMAPIPV6=false

# ── TLS ──────────────────────────────────────────────────────────────────────
# JMAPSKIPVERIFY=false

# ── Authentication ───────────────────────────────────────────────────────────
JMAPUSERNAME=user@fastmail.com
JMAPACCESSTOKEN=fmu1-xxxxxxxx-your-api-token-here
JMAPAUTHMETHOD=bearer

# Getting a Fastmail API token:
#   Settings → Password & Security → API Tokens → New Token

# SMTP — OAuth2 token auth (XOAUTH2 for M365/Google, OAUTHBEARER for RFC 7628 servers)
# Usage: set these variables, then run:
#   gomailtest smtp testauth

# ── Connection ───────────────────────────────────────────────────────────────
SMTPHOST=smtp.office365.com
SMTPPORT=587
SMTPSTARTTLS=true
# SMTPPROXY=http://proxy.example.com:8080

# ── Authentication ───────────────────────────────────────────────────────────
SMTPUSERNAME=user@example.com
SMTPACCESSTOKEN=eyJ0eXAiOiJKV1Qi...your-oauth2-token-here
# SMTPAUTHMETHOD=XOAUTH2      # for Microsoft 365 and Google Workspace
# SMTPAUTHMETHOD=OAUTHBEARER  # for Dovecot and other RFC 7628-compliant servers
SMTPAUTHMETHOD=XOAUTH2

# ── Output ────────────────────────────────────────────────────────────────────
# SMTPVERBOSE=false
# SMTPLOGLEVEL=INFO   # DEBUG, INFO, WARN, ERROR

# IMAP — XOAUTH2 token auth (Microsoft 365 / Google Workspace)
# Usage: set these variables, then run:
#   gomailtest imap testauth|listfolders

# ── Connection ───────────────────────────────────────────────────────────────
IMAPHOST=imap.gmail.com
IMAPPORT=993
IMAPIMAPS=true
# IMAPPROXY=http://proxy.example.com:8080

# ── TLS ──────────────────────────────────────────────────────────────────────
# IMAPSKIPVERIFY=false

# ── Authentication ───────────────────────────────────────────────────────────
IMAPUSERNAME=user@example.com
IMAPACCESSTOKEN=ya29.your-oauth2-token-here
IMAPAUTHMETHOD=XOAUTH2

# ── Output ────────────────────────────────────────────────────────────────────
# IMAPVERBOSE=false
# IMAPLOGLEVEL=INFO   # DEBUG, INFO, WARN, ERROR
